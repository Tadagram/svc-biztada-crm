// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  mod
  agency
  user
  customer
}

enum UserStatus {
  active
  disabled
}

enum AssignmentStatus {
  active
  completed
  revoked
}

enum NotificationType {
  system_alert
  user_action
  worker_assigned
  worker_released
  permission_changed
  account_updated
  custom
}

enum TopUpStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TopUpSourceChannel {
  DIRECT
  WHITELABEL
}

enum CreditLedgerEntryType {
  TOPUP_APPROVED
  USAGE
  ADJUSTMENT
  REFUND
}

enum CreditLedgerDirection {
  CREDIT
  DEBIT
}

enum ServicePackageType {
  personal
  enterprise
}

model Users {
  user_id         String             @id @default(uuid()) @db.Char(36)
  parent_user_id  String?            @db.Char(36)
  agency_name     String?
  phone_number    String             @unique
  role            UserRole?          // null = full admin access (Telegram login); explicit roles for sub-users
  status          UserStatus         @default(active)
  custom_fields   Json?
  balance         Decimal            @default(0) @db.Decimal(15, 2)
  last_active_at  DateTime?          @db.DateTime(0)
  created_at      DateTime           @default(now()) @db.DateTime(0)
  updated_at      DateTime           @default(now()) @updatedAt @db.DateTime(0)
  deleted_at      DateTime?          @db.DateTime(0)

  // Relations
  parent          Users?               @relation("UserToUser", fields: [parent_user_id], references: [user_id])
  children        Users[]              @relation("UserToUser")
  agency_workers  AgencyWorkers[]      @relation("AgencyUser")
  worker_usages   AgencyWorkers[]      @relation("WorkerUsager")
  usage_logs_agency WorkerUsageLogs[]  @relation("LogAgency")
  usage_logs_user   WorkerUsageLogs[]  @relation("LogUser")
  sessions         UserSessions[]
  sent_notifications     Notifications[]  @relation("NotificationSender")
  received_notifications Notifications[]  @relation("NotificationRecipient")
  topup_requests         TopUpRequests[]  @relation("TopUpSubmitter")
  topup_reviews          TopUpRequests[]  @relation("TopUpReviewer")
  credit_balance         UserCreditBalances?
  credit_ledger_entries  CreditLedgerEntries[]

  @@map("users")
}

model UserSessions {
  session_id     String    @id @default(uuid()) @db.Char(36)
  user_id        String    @db.Char(36)
  refresh_token  String    @unique
  expires_at     DateTime  @db.DateTime(0)
  ip_address     String?
  user_agent     String?
  created_at     DateTime  @default(now()) @db.DateTime(0)

  // Relations
  user           Users     @relation(fields: [user_id], references: [user_id])

  @@map("user_sessions")
}

model Permissions {
  permission_id   String             @id @default(uuid()) @db.Char(36)
  name            String
  code            String             @unique
  created_at      DateTime           @default(now()) @db.DateTime(0)
  updated_at      DateTime           @default(now()) @updatedAt @db.DateTime(0)
  deleted_at      DateTime?          @db.DateTime(0)

  // Relations
  role_permissions RolePermissions[]

  @@map("permissions")
}

model RolePermissions {
  role_permission_id String          @id @default(uuid()) @db.Char(36)
  role              String
  permission_id      String          @db.Char(36)
  created_at         DateTime        @default(now()) @db.DateTime(0)
  updated_at         DateTime        @default(now()) @updatedAt @db.DateTime(0)
  deleted_at         DateTime?       @db.DateTime(0)

  // Relations
  permission         Permissions     @relation(fields: [permission_id], references: [permission_id])

  @@map("role_permissions")
}

model Workers {
  worker_id       String             @id @default(uuid()) @db.Char(36)
  name            String
  status          String             @default("ready") // ready, busy, offline
  created_at      DateTime           @default(now()) @db.DateTime(0)
  updated_at      DateTime           @default(now()) @updatedAt @db.DateTime(0)
  deleted_at      DateTime?          @db.DateTime(0)

  // Relations
  agency_workers  AgencyWorkers[]
  usage_logs      WorkerUsageLogs[]

  @@map("workers")
}

model AgencyWorkers {
  agency_worker_id String            @id @default(uuid()) @db.Char(36)
  agency_user_id   String            @db.Char(36)
  worker_id        String            @db.Char(36)
  using_by         String?           @db.Char(36)
  status           AssignmentStatus  @default(active)
  created_at       DateTime          @default(now()) @db.DateTime(0)
  updated_at       DateTime          @default(now()) @updatedAt @db.DateTime(0)
  deleted_at       DateTime?         @db.DateTime(0)

  // Relations
  agency           Users             @relation("AgencyUser", fields: [agency_user_id], references: [user_id])
  worker           Workers           @relation(fields: [worker_id], references: [worker_id])
  user             Users?            @relation("WorkerUsager", fields: [using_by], references: [user_id])

  @@map("agency_workers")
}

model WorkerUsageLogs {
  usage_log_id    String             @id @default(uuid()) @db.Char(36)
  worker_id       String             @db.Char(36)
  agency_user_id  String             @db.Char(36)
  user_id         String             @db.Char(36)
  start_at        DateTime           @default(now()) @db.DateTime(0)
  end_at          DateTime?          @db.DateTime(0)
  metadata        Json?
  created_at      DateTime           @default(now()) @db.DateTime(0)

  // Relations
  worker          Workers            @relation(fields: [worker_id], references: [worker_id])
  agency          Users              @relation("LogAgency", fields: [agency_user_id], references: [user_id])
  user            Users              @relation("LogUser", fields: [user_id], references: [user_id])

  @@map("worker_usage_logs")
}

model Notifications {
  notification_id String            @id @default(uuid()) @db.Char(36)
  recipient_id    String            @db.Char(36)
  sender_id       String?           @db.Char(36)
  type            NotificationType  @default(custom)
  title           String
  body            String
  image_url       String?
  action_url      String?
  custom_fields   Json?
  is_read         Boolean           @default(false)
  read_at         DateTime?         @db.DateTime(0)
  expires_at      DateTime?         @db.DateTime(0)
  created_at      DateTime          @default(now()) @db.DateTime(0)

  // Relations
  recipient       Users             @relation("NotificationRecipient", fields: [recipient_id], references: [user_id])
  sender          Users?            @relation("NotificationSender",    fields: [sender_id],    references: [user_id])

  @@index([recipient_id, is_read])
  @@index([recipient_id, created_at(sort: Desc)])
  @@map("notifications")
}

// key-value store for system-wide settings (survives deploys — stored in DB)
model SystemSettings {
  key        String   @id
  value      String   @db.Text // stores base64 data URLs etc.
  updated_at DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@map("system_settings")
}

model TopUpRequests {
  topup_id      String       @id @default(uuid()) @db.Char(36)
  user_id       String       @db.Char(36)
  amount        Decimal      @db.Decimal(15, 2)
  currency      String       @default("USD") @db.VarChar(8)
  credit_amount Decimal      @db.Decimal(15, 2)
  source_channel TopUpSourceChannel @default(DIRECT)
  sales_agency_uuid String?  @db.Char(36)
  transfer_ref  String?      @db.VarChar(64)  // mã nội dung khách điền khi chuyển khoản
  proof_note    String?      // nội dung CK, ngân hàng, thời gian khách khai
  status        TopUpStatus  @default(PENDING)
  submitted_at  DateTime     @default(now()) @db.DateTime(0)
  reviewed_by   String?      @db.Char(36)  // trace: ai duyệt
  reviewed_at   DateTime?    @db.DateTime(0)
  review_note   String?      // ghi chú duyệt hoặc lý do reject
  created_at    DateTime     @default(now()) @db.DateTime(0)
  updated_at    DateTime     @default(now()) @updatedAt @db.DateTime(0)

  // Relations
  user          Users        @relation("TopUpSubmitter", fields: [user_id],     references: [user_id])
  reviewer      Users?       @relation("TopUpReviewer",  fields: [reviewed_by], references: [user_id])
  credit_ledger_entries CreditLedgerEntries[]

  @@index([status, submitted_at(sort: Desc)])   // reviewer xem PENDING
  @@index([user_id, created_at(sort: Desc)])    // customer xem lịch sử mình
  @@index([reviewed_by])                         // audit theo reviewer
  @@map("topup_requests")
}

model UserCreditBalances {
  user_id           String   @id @db.Char(36)
  available_credits Decimal  @default(0) @db.Decimal(15, 2)
  updated_at        DateTime @default(now()) @updatedAt @db.DateTime(0)

  user              Users    @relation(fields: [user_id], references: [user_id])

  @@map("user_credit_balances")
}

model CreditLedgerEntries {
  credit_entry_id    String                @id @default(uuid()) @db.Char(36)
  user_id            String                @db.Char(36)
  topup_id           String?               @db.Char(36)
  entry_type         CreditLedgerEntryType
  direction          CreditLedgerDirection
  amount             Decimal               @db.Decimal(15, 2)
  balance_after      Decimal               @db.Decimal(15, 2)
  purpose            String?
  source_channel     TopUpSourceChannel    @default(DIRECT)
  sales_agency_uuid  String?               @db.Char(36)
  metadata           Json?
  created_by         String?               @db.Char(36)
  created_at         DateTime              @default(now()) @db.DateTime(0)

  user               Users                 @relation(fields: [user_id], references: [user_id])
  topup              TopUpRequests?        @relation(fields: [topup_id], references: [topup_id])

  @@index([user_id, created_at(sort: Desc)])
  @@index([entry_type, created_at(sort: Desc)])
  @@index([topup_id])
  @@map("credit_ledger_entries")
}

model ServicePackages {
  service_package_id       String             @id @default(uuid()) @db.Char(36)
  product_code             String             @unique @db.VarChar(64)
  price_per_month          Decimal            @db.Decimal(15, 2)
  license_key_count        Int
  facebook_personal_limit  Int
  facebook_fanpage_limit   Int
  zalo_limit               Int
  tiktok_limit             Int
  telegram_limit           Int
  bonus                    String?            @db.VarChar(255)
  agent_discount_percent   Int                @default(0)
  community_support        Boolean            @default(true)
  support_24_7             Boolean            @default(false)
  type                     ServicePackageType
  is_popular               Boolean            @default(false)
  sort_order               Int                @default(0)
  is_active                Boolean            @default(true)
  created_at               DateTime           @default(now()) @db.DateTime(0)
  updated_at               DateTime           @default(now()) @updatedAt @db.DateTime(0)

  @@index([type, is_active, sort_order])
  @@map("service_packages")
}
